# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml.
#
# Secrets policy:
# - Source secrets from a password manager, CI/CD secret store, or shell environment.
# - Keep only indirection in this file (no raw credentials or literals).
# - Rotate tokens/keys on role changes or suspected exposure.
# - Scope tokens to the least privilege needed for image pulls/deploys.
#
# This file must remain safe to commit.

# Optional: extract secrets from 1Password (or another compatible manager).
# SECRETS=$(kamal secrets fetch --adapter 1password --account your-account --from Vault/Item \
#   KAMAL_REGISTRY_PASSWORD RAILS_MASTER_KEY)
# KAMAL_REGISTRY_PASSWORD=$(kamal secrets extract KAMAL_REGISTRY_PASSWORD ${SECRETS})
# RAILS_MASTER_KEY=$(kamal secrets extract RAILS_MASTER_KEY ${SECRETS})

# Registry token used by config/deploy.yml -> registry.password.
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}

# Rails master key used by config/deploy.yml -> env.secret.
# Prefer providing RAILS_MASTER_KEY from a secret manager; fallback reads local file for developer machines.
RAILS_MASTER_KEY=${RAILS_MASTER_KEY:-$(cat config/master.key)}

# Optional build secret for private dependencies.
# GITHUB_TOKEN=${GITHUB_TOKEN}
