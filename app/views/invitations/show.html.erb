<div class="invitation">
  <h1><%= "Accept your invitation" %></h1>

  <p>
    <%= "You have been invited to join" %>
    <strong><%= @invitation.group.name %></strong>
    <%= "with the email" %> <strong><%= @invitation.email %></strong><%= "." %>
  </p>

  <% if @invitation.pending? %>
    <%= form_with url: accept_invitation_path(@invitation.token), method: :post do %>
      <%= submit_tag "Accept invitation", class: "button" %>
    <% end %>
  <% else %>
    <p class="alert alert-warning"><%= "This invitation has already been used." %></p>
  <% end %>
</div>
