<div class="row g-4">
  <div class="col-12">
    <div class="card hero-card border-0">
      <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
          <p class="text-uppercase small mb-1 list-heading"><%= "Dashboard" %></p>
          <h1 class="h3 mb-2"><%= "Keep your circles updated without the pressure to reply." %></h1>
          <p class="mb-0 list-subtitle"><%= "Share photos and notes to one group or everyone at once. Everything is responsive so it feels great on your phone." %></p>
        </div>
        <div class="d-flex flex-column flex-sm-row gap-2">
          <%= link_to "Share an update", new_post_path, class: "btn btn-primary fw-semibold" %>
          <%= link_to "Create a group", new_group_path, class: "btn btn-outline-light" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-4 d-flex flex-column gap-3">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <p class="text-uppercase small mb-0 list-heading"><%= "Groups" %></p>
          <h2 class="h5 mb-0"><%= "Your circles" %></h2>
        </div>
        <%= link_to "New", new_group_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="list-group list-group-flush group-list">
        <% if @groups.any? %>
          <% @groups.each do |group| %>
            <%= link_to group_path(group), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-start" do %>
              <div class="me-3">
                <div class="fw-semibold group-name-strong"><%= group.name %></div>
                <% if group.description.present? %>
                  <small class="text-muted"><%= truncate(group.description, length: 80) %></small>
                <% end %>
              </div>
              <span class="badge rounded-pill text-bg-light border"><%= "View" %></span>
            <% end %>
          <% end %>
        <% else %>
          <div class="list-group-item text-muted"><%= "You haven't joined any groups yet." %></div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <p class="text-uppercase text-muted small mb-1"><%= "Stay connected" %></p>
        <h2 class="h5 mb-2"><%= "Share once, reach everyone" %></h2>
        <p class="text-muted mb-3"><%= "Send a single update to every circle or spin up a new group when plans change." %></p>
        <div class="d-flex flex-wrap gap-2">
          <%= link_to "Post to all groups", new_post_path, class: "btn btn-primary btn-sm" %>
          <%= link_to "Create a new circle", new_group_path, class: "btn btn-outline-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-8">
    <div class="card shadow-sm h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <p class="text-uppercase small mb-0 list-heading"><%= "Group walls" %></p>
          <h2 class="h5 mb-0"><%= "Latest updates" %></h2>
        </div>
        <%= link_to "Post to all", new_post_path, class: "btn btn-sm btn-primary" %>
      </div>
      <div class="card-body">
        <% if @groups.any? %>
          <div class="d-flex flex-column gap-3">
            <% @groups.each do |group| %>
              <% posts = group.posts.order(created_at: :desc) %>
              <div class="group-wall-preview rounded p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <div>
                    <h3 class="h6 mb-0 group-name-strong"><%= group.name %></h3>
                    <small class="text-muted"><%= "Tap to view each wall" %></small>
                  </div>
                  <%= link_to "Open", group_path(group), class: "btn btn-sm btn-outline-secondary" %>
                </div>

                <% if posts.any? %>
                  <div class="list-group list-group-flush post-preview-list">
                    <% posts.first(3).each do |post| %>
                      <%= link_to post_path(post), class: "list-group-item list-group-item-action" do %>
                        <div class="d-flex justify-content-between align-items-start">
                          <div>
                            <div class="fw-semibold text-body"><%= truncate(post.body, length: 80) %></div>
                            <small class="text-muted"><%= "Posted " + time_ago_in_words(post.created_at) + " ago" %></small>
                          </div>
                          <span class="badge text-bg-light border"><%= "View" %></span>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                <% else %>
                  <p class="text-muted mb-0"><%= "No posts in this group yet." %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0"><%= "Join or create a group to start sharing updates." %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
