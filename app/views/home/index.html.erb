<div class="row g-4">
  <div class="col-12">
    <div class="card hero-card border-0">
      <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
          <p class="text-uppercase small mb-1 list-heading"><%= "Dashboard" %></p>
          <h1 class="h3 mb-2"><%= "Keep your circles updated without the pressure to reply." %></h1>
          <p class="mb-0 list-subtitle"><%= "Share photos and notes to one group or everyone at once. Everything is responsive so it feels great on your phone." %></p>
        </div>
        <div class="d-flex flex-column flex-sm-row gap-2">
          <%= link_to "Share an update", new_post_path, class: "btn btn-primary fw-semibold" %>
          <%= link_to "Create a group", new_group_path, class: "btn btn-outline-light" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-4 d-flex flex-column gap-3">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <p class="text-uppercase small mb-0 list-heading"><%= "Contact card" %></p>
          <h2 class="h5 mb-0"><%= "Your details" %></h2>
        </div>
        <%= link_to "Edit", edit_user_registration_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="card-body">
        <div class="mb-2">
          <div class="text-muted small"><%= "Name" %></div>
          <div class="fw-semibold"><%= current_user.display_name %></div>
        </div>

        <div class="mb-2">
          <div class="text-muted small"><%= "Email" %></div>
          <div class="fw-semibold"><%= current_user.email %></div>
        </div>

        <% if current_user.birthday.present? %>
          <div class="mb-2">
            <div class="text-muted small"><%= "Birthday" %></div>
            <div class="fw-semibold"><%= current_user.birthday.strftime("%B %-d, %Y") %></div>
          </div>
        <% end %>

        <% if current_user.spouse_name.present? || current_user.spouse_birthday.present? %>
          <div class="mb-2">
            <div class="text-muted small"><%= "Spouse / Partner" %></div>
            <div class="fw-semibold"><%= current_user.spouse_name.presence || "Not listed" %></div>
            <% if current_user.spouse_birthday.present? %>
              <div class="small text-muted"><%= "Birthday: " %><%= current_user.spouse_birthday.strftime("%B %-d, %Y") %></div>
            <% end %>
          </div>
        <% end %>

        <% if current_user.home_address.present? %>
          <div class="mb-2">
            <div class="text-muted small"><%= "Home address" %></div>
            <div class="fw-semibold"><%= simple_format(current_user.home_address) %></div>
          </div>
        <% end %>

        <% if current_user.contact_notes.present? %>
          <div class="mb-3">
            <div class="text-muted small"><%= "Other details" %></div>
            <div><%= simple_format(current_user.contact_notes) %></div>
          </div>
        <% end %>

        <div class="mt-3">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
              <p class="text-uppercase small mb-0 list-heading"><%= "Family" %></p>
              <h3 class="h6 mb-0"><%= "Children" %></h3>
            </div>
          </div>

          <% if current_user.children.any? %>
            <div class="list-group list-group-flush">
              <% current_user.children.each do |child| %>
                <div class="list-group-item">
                  <div class="fw-semibold"><%= child.name %></div>
                  <div class="small text-muted">
                    <% if child.age_display.present? %>
                      <span class="me-2"><%= "Age: " %><%= child.age_display %></span>
                      <br>
                    <% end %>
                    <% if child.birthday.present? %>
                      <span><%= "Birthday: " %><%= child.birthday.strftime("%B %-d, %Y") %></span>
                    <% end %>
                  </div>
                  <% if child.notes.present? %>
                    <div class="small mt-1"><%= child.notes %></div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-muted small mb-0"><%= "Add names and birthdays so friends can stay in the loop." %></p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <p class="text-uppercase small mb-0 list-heading"><%= "Groups" %></p>
          <h2 class="h5 mb-0"><%= "Your circles" %></h2>
        </div>
        <%= link_to "New", new_group_path, class: "btn btn-sm btn-outline-primary" %>
      </div>
      <div class="list-group list-group-flush group-list">
        <% if @groups.any? %>
          <% @groups.each do |group| %>
            <%= link_to group_path(group), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-start" do %>
              <div class="me-3">
                <div class="fw-semibold group-name-strong"><%= group.name %></div>
                <% if group.description.present? %>
                  <small class="text-muted"><%= truncate(group.description, length: 80) %></small>
                <% end %>
              </div>
              <span class="badge rounded-pill text-bg-light border"><%= "View" %></span>
            <% end %>
          <% end %>
        <% else %>
          <div class="list-group-item text-muted"><%= "You haven't joined any groups yet." %></div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <p class="text-uppercase small mb-0 list-heading"><%= "People" %></p>
          <h2 class="h5 mb-0"><%= "Contacts" %></h2>
        </div>
        <%= link_to "Directory", directory_path, class: "badge text-bg-light border text-decoration-none" %>
      </div>

      <div class="list-group list-group-flush">
        <% if @people.any? %>
          <% @people.each do |person| %>
            <%= link_to user_path(person), class: "list-group-item list-group-item-action" do %>
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div class="flex-grow-1">
                  <div class="fw-semibold"><%= person.display_name %></div>
                  <div class="small text-muted"><%= person.email %></div>
                  <% if person.spouse_name.present? %>
                    <div class="small"><%= "Spouse/Partner: " %><span class="text-muted"><%= person.spouse_name %></span></div>
                  <% end %>
                  <% if person.home_address.present? %>
                    <div class="small text-muted mt-1">
                      <%= simple_format(person.home_address, class: "mb-0") %>
                    </div>
                  <% end %>
                </div>
                <% if person.children.any? %>
                  <div class="small text-muted text-end">
                    <div class="fw-semibold text-body"><%= "Children" %></div>
                    <% person.children.each do |child| %>
                      <div>
                        <%= child.name %>
                        <% if child.age_display.present? %>
                          <span class="ms-1">(<%= child.age_display %>)</span>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
          <% if @people_total.to_i > @people.size %>
            <div class="list-group-item text-muted small bg-light">
              <%= "Showing the first 15 contacts." %>
              <%= link_to "View all", directory_path, class: "ms-1" %>
            </div>
          <% end %>
        <% else %>
          <div class="list-group-item text-muted"><%= "No people to show yet." %></div>
        <% end %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <p class="text-uppercase text-muted small mb-1"><%= "Stay connected" %></p>
        <h2 class="h5 mb-2"><%= "Share once, reach everyone" %></h2>
        <p class="text-muted mb-3"><%= "Send a single update to every circle or spin up a new group when plans change." %></p>
        <div class="d-flex flex-wrap gap-2">
          <%= link_to "Post to all groups", new_post_path, class: "btn btn-primary btn-sm" %>
          <%= link_to "Create a new circle", new_group_path, class: "btn btn-outline-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-8">
    <div class="card shadow-sm h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <div>
          <p class="text-uppercase small mb-0 list-heading"><%= "Group walls" %></p>
          <h2 class="h5 mb-0"><%= "Latest updates" %></h2>
        </div>
        <%= link_to "Post to all", new_post_path, class: "btn btn-sm btn-primary" %>
      </div>
      <div class="card-body">
        <% if @groups.any? %>
          <div class="d-flex flex-column gap-3">
            <% @groups.each do |group| %>
              <% posts = group.posts.order(created_at: :desc) %>
              <% if posts.present? %>
                <div class="group-wall-preview rounded p-3">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                      <h3 class="h6 mb-0 group-name-strong"><%= group.name %></h3>
                      <small class="text-muted"><%= "Tap to view each wall" %></small>
                    </div>
                    <%= link_to "Open", group_path(group), class: "btn btn-sm btn-outline-secondary" %>
                  </div>

                  <% if posts.any? %>
                    <div class="list-group list-group-flush post-preview-list">
                      <% posts.first(3).each do |post| %>
                        <%= link_to post_path(post), class: "list-group-item list-group-item-action" do %>
                          <div class="d-flex justify-content-between align-items-start">
                            <div>
                              <div class="fw-semibold text-body"><%= truncate(post.body, length: 80) %></div>
                              <small class="text-muted"><%= "Posted " + time_ago_in_words(post.created_at) + " ago" %></small>
                            </div>
                            <span class="badge text-bg-light border"><%= "View" %></span>
                          </div>
                        <% end %>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="text-muted mb-0"><%= "No posts in this group yet." %></p>
                  <% end %>
                </div>
            <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-muted mb-0"><%= "Join or create a group to start sharing updates." %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
