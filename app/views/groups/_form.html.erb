<%= form_with model: @group, local: true, html: { class: "card shadow-sm" } do |form| %>
  <div class="card-body d-flex flex-column gap-3">
    <% if @group.errors.any? %>
      <div class="alert alert-danger">
        <h2 class="h6 mb-2"><%= "#{pluralize(@group.errors.count, "error")} prevented this group from saving:" %></h2>
        <ul class="mb-0 ps-3">
          <% @group.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-floating">
      <%= form.text_field :name, class: "form-control", placeholder: "Group name", required: true %>
      <%= form.label :name, "Group name" %>
    </div>

    <div class="form-floating">
      <%= form.text_area :description, rows: 3, class: "form-control", placeholder: "What should members expect here?", style: "height: 120px" %>
      <%= form.label :description, "Description (optional)" %>
      <div class="form-text"><%= "Help friends know what this space is for." %></div>
    </div>
  </div>
  <div class="card-footer bg-white d-flex justify-content-between">
    <%= link_to "Cancel", groups_path, class: "btn btn-outline-secondary" %>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
