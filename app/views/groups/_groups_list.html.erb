<div class="row g-3 g-lg-4 groups-grid">
  <% if groups.any? %>
    <% groups.each do |group| %>
      <div class="col-12 col-md-6">
        <div class="card directory-card group-card shadow-sm h-100 position-relative">
          <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex justify-content-between align-items-start">
              <div>
                <h2 class="h5 mb-1"><%= group.name %></h2>
                <% if group.description.present? %>
                  <p class="text-muted mb-0"><%= truncate(group.description, length: 120) %></p>
                <% else %>
                  <p class="text-muted mb-0"><%= "No description provided." %></p>
                <% end %>
              </div>
              <span class="badge text-bg-light border"><%= "Group" %></span>
            </div>
            <div class="d-flex gap-2 flex-wrap mt-auto position-relative z-1 align-items-center">
              <div class="group-meta text-muted small"><%= "#{group.users.count} members" %></div>
              <% if group.memberships.find_by(user: current_user)&.admin? %>
                <%= link_to "Edit", edit_group_path(group), class: "btn btn-sm btn-outline-secondary", data: { turbo_frame: "_top" } %>
              <% end %>
            </div>
            <%= link_to "",
                        group_path(group),
                        class: "stretched-link",
                        aria: { label: "View #{group.name}" },
                        data: { turbo_frame: "_top" } %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12">
      <div class="alert alert-info"><%= "You haven't joined any groups yet. Create one to get started!" %></div>
    </div>
  <% end %>
</div>

<%= render "shared/pagination",
           collection: groups,
           label: "Groups pagination",
           path_for_page: ->(page) { groups_path(page: page, format: :turbo_stream) } %>
