<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Group invitations" %></p>
    <h1 class="h4 mb-0"><%= @group.name %></h1>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Back to group", @group, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card mb-4 shadow-sm">
  <div class="card-body">
    <h2 class="h5 mb-3"><%= "Invite people by email" %></h2>
    <p class="text-muted small mb-3"><%= "People already in any of your groups will be skipped so that each person stays tied to a single circle." %></p>

    <%= form_with url: group_invitations_path(@group), scope: :invitation, method: :post, local: true do |form| %>
      <div class="mb-3">
        <%= form.label :emails, "Email addresses", class: "form-label fw-semibold" %>
        <%= form.text_area :emails, rows: 3, class: "form-control", placeholder: "one@example.com, another@example.com" %>
        <p class="text-muted small mb-0 mt-1"><%= "Separate addresses with commas, spaces, or new lines." %></p>
      </div>

      <%= form.submit "Create invite links", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h2 class="h6 mb-0 text-uppercase text-muted"><%= "Existing invites" %></h2>
      <span class="badge text-bg-light border"><%= pluralize(@invitations.pending.count, "pending invite") %></span>
    </div>

    <% if @invitations.any? %>
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th scope="col"><%= "Email" %></th>
              <th scope="col"><%= "Status" %></th>
              <th scope="col"><%= "Link to share" %></th>
              <th scope="col"><%= "Invited by" %></th>
              <th scope="col"><%= "Invited on" %></th>
            </tr>
          </thead>
          <tbody>
            <% @invitations.each do |invitation| %>
              <tr>
                <td class="fw-semibold"><%= invitation.email %></td>
                <td>
                  <% if invitation.pending? %>
                    <span class="badge text-bg-warning"><%= "Pending" %></span>
                  <% else %>
                    <span class="badge text-bg-success"><%= "Accepted" %></span>
                  <% end %>
                </td>
                <td>
                  <% if invitation.pending? %>
                    <div class="d-flex align-items-center gap-2">
                      <code class="small"><%= invitation_path(invitation.token) %></code>
                    </div>
                  <% else %>
                    <span class="text-muted small"><%= "Used" %></span>
                  <% end %>
                </td>
                <td><%= invitation.inviter.display_name %></td>
                <td><%= l(invitation.created_at.to_date, format: :long) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-muted mb-0"><%= "No invites yet. Add some emails above to generate invite links." %></p>
    <% end %>
  </div>
</div>
