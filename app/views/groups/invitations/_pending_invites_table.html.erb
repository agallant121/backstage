<%# Pending invitations %>
<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h2 class="h6 mb-0 text-uppercase text-muted"><%= "Existing invites" %></h2>
      <span class="badge text-bg-light border"><%= pluralize(@pending_invitations&.count, "pending invite") %></span>
    </div>

    <% cache [@group, "pending_invitations_table", @pending_invitations.count, @pending_invitations.maximum(:updated_at)], expires_in: 10.minutes do %>
      <div class="table-responsive mb-4">
        <table class="table align-middle">
          <thead>
            <tr>
              <th scope="col"><%= "Email" %></th>
              <th scope="col"><%= "Status" %></th>
              <th scope="col"><%= "Link to share" %></th>
              <th scope="col"><%= "Expires" %></th>
              <th scope="col"><%= "Invited by" %></th>
              <th scope="col"><%= "Invited on" %></th>
            </tr>
          </thead>
          <tbody>
            <% @pending_invitations.each do |invitation| %>
              <tr>
                <td class="fw-semibold"><%= invitation.email %></td>
                <td>
                  <% if invitation.expired? %>
                    <span class="badge text-bg-secondary"><%= "Expired" %></span>
                  <% else %>
                    <span class="badge text-bg-warning"><%= "Pending" %></span>
                  <% end %>
                </td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <% if invitation.expired? %>
                      <%= button_to "Reissue",
                                    reissue_group_invitation_path(@group, invitation),
                                    method: :post,
                                    class: "btn btn-sm btn-outline-primary" %>
                    <% else %>
                      <code class="small"><%= invitation_path(invitation.token) %></code>
                    <% end %>
                  </div>
                </td>
                <td><%= l(invitation.expires_at.to_date, format: :long) %></td>
                <td><%= invitation.inviter.display_name %></td>
                <td><%= l(invitation.created_at.to_date, format: :long) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

  </div>
</div>
