<% member = @group.users.include?(current_user) %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Group" %></p>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <h1 class="h4 mb-0"><%= @group.name %></h1>
      <% if member %>
        <span class="badge membership-badge px-3 py-2"><%= "You are a member of this group" %></span>
      <% end %>
    </div>
  </div>
  <div class="d-flex gap-2 flex-wrap align-items-center">
    <% unless member %>
      <%= button_to "Join Group", group_memberships_path(@group), method: :post, class: "btn btn-outline-primary" %>
    <% end %>
    <%= link_to "Back to groups", groups_path, class: "btn btn-outline-secondary" %>
    <%= link_to "New post in this group", new_post_path(group_id: @group.id), class: "btn btn-primary" %>
  </div>
</div>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
  <div class="d-flex flex-column gap-1">
    <p class="text-uppercase text-muted small mb-0"><%= "About" %></p>
    <% if @group.description.present? %>
      <p class="mb-0 text-secondary"><%= @group.description %></p>
    <% else %>
      <p class="mb-0 text-secondary"><%= "No description added yet." %></p>
    <% end %>
  </div>

</div>

  <div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="h5 mb-0"><%= "Posts in this group" %></h2>
    <%= link_to "Post an update", new_post_path(group_id: @group.id), class: "btn btn-sm btn-primary" %>
  </div>

<% if @posts.present? %>
  <div class="d-flex flex-column gap-3">
    <% @posts.each do |post| %>
      <div class="card shadow-sm post-card">
        <div class="card-body d-flex flex-column gap-3">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <p class="post-meta small mb-1"><%= "Posted by " + (post.user&.email || "Unknown author") %></p>
              <p class="post-meta small mb-0"><%= "Posted " + time_ago_in_words(post.created_at) + " ago" %></p>
            </div>
            <div class="badge text-bg-light border"><%= "Shared update" %></div>
          </div>

          <div class="fs-6">
            <%= simple_format(post.body) %>
          </div>

          <% if post.images.attached? %>
            <hr class="muted-divider">
            <div class="d-flex flex-column gap-2">
              <p class="fw-semibold mb-1"><%= "Images" %></p>
              <div class="post-attachment-grid">
                <% post.images.each do |image| %>
                  <div class="post-attachment">
                    <%= image_tag(image, class: "img-fluid w-100 h-auto", loading: "lazy", decoding: "async") %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-light border"><%= "No posts in this group yet." %></div>
<% end %>
