<% membership = current_user.memberships.find_by(group: @group) %>
<% member = membership.present? %>
<% admin = membership&.admin? %>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Group" %></p>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <h1 class="h4 mb-0"><%= @group.name %></h1>
      <% if member %>
        <span class="badge membership-badge px-3 py-2"><%= "You are a member of this group" %></span>
      <% end %>
    </div>
  </div>
  <div class="d-flex gap-2 flex-wrap align-items-center">
    <% unless member %>
      <%= button_to "Join Group", group_memberships_path(@group), method: :post, class: "btn btn-outline-primary" %>
    <% end %>
    <% if admin %>
      <%= link_to "Manage invites", group_invitations_path(@group), class: "btn btn-outline-secondary" %>
    <% end %>
    <%= link_to "Back to groups", groups_path, class: "btn btn-outline-secondary" %>
    <%= link_to "New post in this group", new_post_path(group_id: @group.id), class: "btn btn-primary" %>
  </div>
</div>

<div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
<div class="d-flex flex-column gap-1">
  <p class="text-uppercase text-muted small mb-0"><%= "About" %></p>
  <% if @group.description.present? %>
    <p class="mb-0 text-secondary"><%= @group.description %></p>
  <% else %>
    <p class="mb-0 text-secondary"><%= "No description added yet." %></p>
  <% end %>
</div>
</div>

<div class="d-flex align-items-center gap-2 flex-wrap text-muted mb-4">
  <span class="text-uppercase small"><%= "Group members" %></span>
  <span class="fw-semibold text-body"><%= pluralize(@group.users.count, "member") %></span>
  <%= link_to "View members", members_group_path(@group), class: "btn btn-outline-secondary btn-sm" %>
</div>

<% if @has_posts %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body d-flex flex-column gap-2">
      <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <div>
          <p class="text-uppercase text-muted small mb-1"><%= "AI recap" %></p>
          <h2 class="h6 mb-0"><%= "What everyone has shared lately" %>:</h2>
        </div>
        <% if @group.message_summary_generated_at.present? %>
          <span class="small text-muted">
            <%= "Updated " + time_ago_in_words(@group.message_summary_generated_at) + " ago" %>
          </span>
        <% end %>
      </div>

      <% if @group.message_summary.present? %>
        <div class="mb-0 text-secondary"><%= simple_format(@group.message_summary) %></div>
      <% elsif @group.message_summary_source == "unavailable" %>
        <p class="mb-0 text-secondary"><%= "AI summaries are not configured yet for this environment." %></p>
      <% elsif @group.message_summary_source == "error" %>
        <p class="mb-0 text-secondary"><%= "The AI summary could not be generated from the latest updates yet." %></p>
      <% else %>
        <p class="mb-0 text-secondary"><%= "A summary will appear here after the latest group updates finish processing." %></p>
      <% end %>
    </div>
  </div>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-2">
  <h2 class="h5 mb-0"><%= "Posts in this group" %></h2>
  <%= link_to "Post an update", new_post_path(group_id: @group.id), class: "btn btn-sm btn-primary" %>
</div>

<%= turbo_frame_tag "posts_list" do %>
  <% toggle_path = @view_mode == :full ? group_path(@group) : group_path(@group, view: "full") %>
  <%= render "posts/post_list",
             posts: @posts,
             view_mode: @view_mode,
             group: @group,
             toggle_path: toggle_path,
             show_actions: false,
             show_group_badges: false,
             header_badge_label: "Shared update",
             empty_state_message: "No posts in this group yet." %>
<% end %>
