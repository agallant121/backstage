<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2 page-intro page-intro--groups">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Groups" %></p>
    <h1 class="h4 mb-0"><%= "Your groups" %></h1>
  </div>
  <%= link_to "New group", new_group_path, class: "btn btn-primary" %>
</div>

<%= turbo_frame_tag "groups_list" do %>
