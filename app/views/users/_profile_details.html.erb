<div class="profile-field mb-3">
  <div class="text-muted small"><%= "Email" %></div>
  <div class="fw-semibold"><%= user.email %></div>
</div>

<% if user.birthday.present? %>
  <div class="profile-field mb-3">
    <div class="text-muted small"><%= "Birthday" %></div>
    <div class="fw-semibold"><%= user.birthday.strftime("%B %-d, %Y") %></div>
  </div>
<% end %>

<% if user.spouse_name.present? || user.spouse_birthday.present? %>
  <div class="profile-field mb-3">
    <div class="text-muted small"><%= "Spouse / Partner" %></div>
    <div class="fw-semibold"><%= user.spouse_name.presence || "Not listed" %></div>
    <% if user.spouse_birthday.present? %>
      <div class="small text-muted mt-1"><%= "Birthday: " %><%= user.spouse_birthday.strftime("%B %-d, %Y") %></div>
    <% end %>
  </div>
<% end %>

<% if user.home_address.present? %>
  <div class="profile-field mb-3">
    <div class="text-muted small"><%= "Home address" %></div>
    <div class="fw-semibold"><%= simple_format(user.home_address) %></div>
  </div>
<% end %>

<% if user.contact_notes.present? %>
  <div class="profile-field mb-4">
    <div class="text-muted small"><%= "Other details" %></div>
    <div><%= simple_format(user.contact_notes) %></div>
  </div>
<% end %>

<div class="profile-children mt-3">
  <div class="d-flex align-items-center justify-content-between mb-2">
    <div>
      <p class="text-uppercase small mb-0 list-heading"><%= "Family" %></p>
      <h2 class="h6 mb-0"><%= "Children" %></h2>
    </div>
  </div>

  <% if user.children.any? %>
    <div class="list-group list-group-flush profile-children-list">
      <% user.children.each do |child| %>
        <div class="list-group-item">
          <div class="fw-semibold"><%= child.name %></div>
          <div class="small text-muted">
            <% if child.age_display.present? %>
              <span class="me-2"><%= "Age: " %><%= child.age_display %></span>
            <% end %>
            <% if child.birthday.present? %>
              <span><%= "Birthday: " %><%= child.birthday.strftime("%B %-d, %Y") %></span>
            <% end %>
          </div>
          <% if child.notes.present? %>
            <div class="small mt-1"><%= child.notes %></div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="profile-field text-muted small mb-0"><%= "No children listed." %></p>
  <% end %>
</div>
