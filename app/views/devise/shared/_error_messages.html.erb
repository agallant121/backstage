<% if resource.errors.any? %>
  <div class="alert alert-danger shadow-sm" role="alert">
    <p class="mb-2 fw-semibold"><%= "Please fix the following:" %></p>
    <ul class="mb-0 ps-3">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
