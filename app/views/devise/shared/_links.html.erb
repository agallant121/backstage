<% links = [] %>

<% if controller_name != 'sessions' %>
  <% links << link_to("Sign in", new_session_path(resource_name), class: "auth-link") %>
<% end %>

<% if controller_name == 'sessions' %>
  <% links << content_tag(:span, "Sign up is invitation-only.") %>
<% end %>

<% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <% links << link_to("Forgot your password?", new_password_path(resource_name), class: "auth-link") %>
<% end %>

<% if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <% links << link_to("Didn't receive confirmation instructions?", send("new_#{resource_name}_confirmation_path"), class: "auth-link") %>
<% end %>

<% if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <% links << link_to("Didn't receive unlock instructions?", send("new_#{resource_name}_unlock_path"), class: "auth-link") %>
<% end %>

<% if links.any? %>
  <div class="auth-links text-center mt-4 small text-muted">
    <%= safe_join(links, content_tag(:span, "•", class: "mx-2 text-muted")) %>
  </div>
<% end %>
