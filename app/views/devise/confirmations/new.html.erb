<div class="auth-shell py-5">
  <div class="auth-card card mx-auto shadow-lg">
    <div class="card-body p-4 p-sm-5">
      <p class="text-uppercase fw-semibold text-muted small mb-1"><%= "Email confirmation" %></p>
      <h1 class="h3 fw-bold mb-3"><%= "Resend confirmation instructions" %></h1>
      <p class="text-muted mb-4"><%= "We'll send a fresh confirmation link to your inbox." %></p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name)) do |f| %>
        <div class="mb-4">
          <%= f.label :email, "Email", class: "form-label fw-semibold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email) %>
        </div>

        <div class="d-grid gap-3">
          <%= f.submit "Send confirmation", class: "btn btn-primary btn-lg" %>
          <%= link_to "Back to sign in", new_session_path(resource_name), class: "btn btn-outline-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
