<div class="auth-shell py-5">
  <div class="auth-card card mx-auto shadow-lg">
    <div class="card-body p-4 p-sm-5">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <p class="text-uppercase fw-semibold text-muted small mb-1"><%= "Join the circles" %></p>
          <h1 class="h3 fw-bold mb-0"><%= "Create your account" %></h1>
        </div>
        <div class="badge bg-secondary text-dark border border-secondary"><%= "New" %></div>
      </div>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :email, "Email", class: "form-label fw-semibold" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
        </div>

        <% if resource.respond_to?(:name) %>
          <div class="mb-3">
            <%= f.label :name, "Name", class: "form-label fw-semibold" %>
            <%= f.text_field :name, class: "form-control form-control-lg" %>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :password, "Password", class: "form-label fw-semibold" %>
          <% if @minimum_password_length %>
            <p class="text-muted small mb-1"><%= "Minimum password length: #{@minimum_password_length} characters" %></p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg" %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, "Confirm password", class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
        </div>

        <div class="d-grid gap-3">
          <%= f.submit "Sign up", class: "btn btn-primary btn-lg" %>
          <div class="text-center text-muted small"><%= "By continuing, you agree to keep your groups up to date." %></div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
