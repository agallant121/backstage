<div class="auth-shell py-5">
  <div class="auth-card card mx-auto shadow-lg">
    <div class="card-body p-4 p-sm-5">
      <p class="text-uppercase fw-semibold text-muted small mb-1"><%= "Account" %></p>
      <h1 class="h3 fw-bold mb-3"><%= "Edit profile" %></h1>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <div class="row g-3">
          <div class="col-md-6">
            <%= f.label :first_name, "First name", class: "form-label fw-semibold" %>
            <%= f.text_field :first_name, class: "form-control form-control-lg" %>
          </div>
          <div class="col-md-6">
            <%= f.label :last_name, "Last name", class: "form-label fw-semibold" %>
            <%= f.text_field :last_name, class: "form-control form-control-lg" %>
          </div>
        </div>

        <div class="row g-3 mt-1">
          <div class="col-md-6">
            <%= f.label :email, "Email", class: "form-label fw-semibold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control form-control-lg" %>
          </div>
          <div class="col-md-6">
            <%= f.label :birthday, "Birthday", class: "form-label fw-semibold" %>
            <%= f.date_field :birthday, class: "form-control form-control-lg" %>
          </div>
        </div>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="alert alert-info" role="alert">
            <%= "Currently waiting confirmation for: #{resource.unconfirmed_email}" %>
          </div>
        <% end %>

        <div class="row g-3 mt-1">
          <div class="col-md-6">
            <%= f.label :spouse_name, "Spouse/Partner", class: "form-label fw-semibold" %>
            <%= f.text_field :spouse_name, class: "form-control form-control-lg" %>
          </div>
          <div class="col-md-6">
            <%= f.label :spouse_birthday, "Spouse birthday", class: "form-label fw-semibold" %>
            <%= f.date_field :spouse_birthday, class: "form-control form-control-lg" %>
          </div>
        </div>

        <div class="mt-3">
          <%= f.label :home_address, "Home address", class: "form-label fw-semibold" %>
          <%= f.text_area :home_address, rows: 3, class: "form-control" %>
          <p class="text-muted small mb-0 mt-1"><%= "Include mailing details so friends can send cards or invites." %></p>
        </div>

        <div class="mt-3">
          <%= f.label :contact_notes, "Other details", class: "form-label fw-semibold" %>
          <%= f.text_area :contact_notes, rows: 3, class: "form-control" %>
          <p class="text-muted small mb-0 mt-1"><%= "Any tidbits long-time acquaintances should know (best phone number, anniversaries, etc.)." %></p>
        </div>

        <% child_records = resource.children.to_a %>
        <% if child_records.empty? %>
          <% 3.times { child_records << resource.children.build } %>
        <% end %>
        <% child_records << resource.children.build if child_records.none?(&:new_record?) %>

        <div class="mt-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div>
              <p class="text-uppercase small mb-0 list-heading"><%= "Family" %></p>
              <h2 class="h5 mb-0"><%= "Children" %></h2>
            </div>
            <span class="badge text-bg-light border"><%= "Optional" %></span>
          </div>

          <div class="d-flex flex-column gap-3">
            <%= f.fields_for :children, child_records do |child_form| %>
              <div class="border rounded p-3">
                <%= child_form.hidden_field :id %>
                <div class="row g-3">
                  <div class="col-md-6">
                    <%= child_form.label :name, "Name", class: "form-label fw-semibold" %>
                    <%= child_form.text_field :name, class: "form-control" %>
                  </div>
                  <div class="col-md-6">
                    <%= child_form.label :birthday, "Birthday", class: "form-label fw-semibold" %>
                    <%= child_form.date_field :birthday, class: "form-control" %>
                  </div>
                </div>
                <div class="mt-2">
                  <%= child_form.label :notes, "Notes", class: "form-label fw-semibold" %>
                  <%= child_form.text_area :notes, rows: 2, class: "form-control" %>
                </div>
                <div class="form-check mt-2">
                  <%= child_form.check_box :_destroy, class: "form-check-input" %>
                  <%= child_form.label :_destroy, "Remove this child", class: "form-check-label" %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="mt-4">
          <%= f.label :password, "New password", class: "form-label fw-semibold" %>
          <p class="text-muted small mb-1"><%= "Leave blank if you don't want to change it." %></p>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control form-control-lg" %>
        </div>

        <div class="mt-3">
          <%= f.label :password_confirmation, "Confirm new password", class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control form-control-lg" %>
        </div>

        <div class="mt-4">
          <%= f.label :current_password, "Current password", class: "form-label fw-semibold" %>
          <p class="text-muted small mb-1"><%= "We need your current password to confirm your changes." %></p>
          <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control form-control-lg" %>
        </div>

        <div class="d-grid gap-3 mt-4">
          <%= f.submit "Update", class: "btn btn-primary btn-lg" %>
          <%= link_to "Cancel", root_path, class: "btn btn-outline-primary" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
