<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 18px;">
  <tr>
    <td style="padding: 6px 12px; background-color: rgba(249, 215, 165, 0.25); border: 1px solid rgba(249, 215, 165, 0.5); border-radius: 999px; font-size: 12px; font-weight: 700; color: #b1751f; text-transform: uppercase; letter-spacing: 0.08em;">
      <%= "Security" %>
    </td>
  </tr>
</table>
<h1 style="margin: 0 0 12px; font-size: 26px; font-weight: 750; color: #1d2329;"><%= "Reset your password" %></h1>
<p style="margin: 0 0 16px; font-size: 15px; line-height: 1.7; color: #2d3035;">
  <%= "Hi #{@resource.email}, we received a request to reset your Backstage password." %>
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 24px; border-radius: 14px; background-color: #fff9ef; border: 1px solid rgba(249, 215, 165, 0.45);">
  <tr>
    <td style="padding: 14px 16px; font-size: 14px; line-height: 1.6; color: #2d3035;">
      <%= "Use the button below to create a new password. This link expires soon for your security." %>
    </td>
  </tr>
</table>
<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px;">
  <tr>
    <td style="background-color: #7FD1C8; border-radius: 12px; box-shadow: 0 10px 18px rgba(127, 209, 200, 0.35);">
      <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" style="display: inline-block; padding: 12px 24px; font-size: 15px; font-weight: 700; color: #ffffff; text-decoration: none;"><%= "Choose a new password" %></a>
    </td>
  </tr>
</table>
<p style="margin: 0 0 16px; font-size: 13px; color: #71757c;"><%= "If you did not request this change, you can safely ignore this email." %></p>
<p style="margin: 0 0 8px; font-size: 13px; color: #71757c;"><%= "If the button does not work, copy and paste this link into your browser:" %></p>
<p style="margin: 0; font-size: 13px; color: #3c8d85; word-break: break-all;">
  <a href="<%= edit_password_url(@resource, reset_password_token: @token) %>" style="color: #3c8d85; text-decoration: none;"><%= edit_password_url(@resource, reset_password_token: @token) %></a>
</p>
