<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 18px;">
  <tr>
    <td style="padding: 6px 12px; background-color: rgba(127, 209, 200, 0.18); border: 1px solid rgba(127, 209, 200, 0.4); border-radius: 999px; font-size: 12px; font-weight: 700; color: #3c8d85; text-transform: uppercase; letter-spacing: 0.08em;">
      <%= "Account update" %>
    </td>
  </tr>
</table>
<h1 style="margin: 0 0 12px; font-size: 26px; font-weight: 750; color: #1d2329;"><%= "Your email has been updated" %></h1>
<p style="margin: 0 0 16px; font-size: 15px; line-height: 1.7; color: #2d3035;">
  <%= "Hi #{@resource.email}, this is a confirmation that your Backstage email address has been updated." %>
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 16px; border-radius: 14px; background-color: #f6fbfa; border: 1px solid rgba(127, 209, 200, 0.35);">
  <tr>
    <td style="padding: 12px 16px; font-size: 13px; line-height: 1.6; color: #2d3035;">
      <%= "If you did not request this change, please contact support right away." %>
    </td>
  </tr>
</table>
