<% query ||= nil %>
<% if people.any? %>
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
    <% people.each do |person| %>
      <% shared_groups = person.groups & user_groups %>
      <div class="col">
        <%= link_to user_path(person), class: "card directory-card h-100 shadow-sm text-decoration-none text-body d-block", data: { turbo_frame: "_top" } do %>
          <div class="card-body d-flex flex-column">
            <div class="mb-2">
              <div class="text-uppercase small text-muted list-heading mb-0"><%= "Contact" %></div>
              <h2 class="h5 mb-1"><%= person.display_name %></h2>
              <div class="small text-muted"><%= person.email %></div>
            </div>

            <div class="small text-uppercase text-muted fw-semibold mb-2"><%= "Details" %></div>
            <ul class="list-unstyled small mb-3 flex-grow-1">
              <% if person.spouse_name.present? %>
                <li class="mb-1"><span class="fw-semibold text-body"><%= "Spouse/Partner:" %></span> <span class="text-muted"><%= person.spouse_name %></span></li>
              <% end %>
              <% if person.home_address.present? %>
                <li class="mb-1">
                  <div class="fw-semibold text-body"><%= "Home address" %></div>
                  <div class="text-muted"><%= simple_format(person.home_address, class: "mb-0") %></div>
                </li>
              <% end %>
              <% if person.contact_notes.present? %>
                <li class="mb-1">
                  <div class="fw-semibold text-body"><%= "Other details" %></div>
                  <div class="text-muted"><%= simple_format(person.contact_notes, class: "mb-0") %></div>
                </li>
              <% end %>
              <% if person.children.any? %>
                <li>
                  <div class="fw-semibold text-body"><%= "Children" %></div>
                  <ul class="list-unstyled text-muted mb-0">
                    <% person.children.each do |child| %>
                      <li>
                        <%= child.name %>
                        <% if child.age_display.present? %>
                          <span class="ms-1">(<%= child.age_display %>)</span>
                        <% end %>
                      </li>
                    <% end %>
                  </ul>
                </li>
              <% end %>
            </ul>

            <div class="mt-auto d-flex flex-column gap-2">
              <% if shared_groups.any? %>
                <div class="small">
                  <div class="text-uppercase text-muted fw-semibold mb-1"><%= "Shared groups" %></div>
                  <div class="d-flex flex-wrap gap-1">
                    <% shared_groups.each do |group| %>
                      <span class="badge text-bg-light border"><%= group.name %></span>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <div>
                <span class="btn btn-sm btn-outline-primary w-100"><%= "View profile" %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= render "shared/pagination",
             collection: people,
             label: "Directory pagination",
             path_for_page: ->(page) { directory_path(page: page, query: query.presence, format: :turbo_stream) } %>
<% else %>
  <div class="alert alert-secondary" role="alert">
    <% if query.present? %>
      <%= "No contacts match your search yet." %>
    <% else %>
      <%= "Join or create a group to start building your directory." %>
    <% end %>
  </div>
<% end %>
