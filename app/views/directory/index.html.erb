<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4 page-intro page-intro--directory">
  <div>
    <p class="text-uppercase small mb-1 list-heading"><%= "Directory" %></p>
    <h1 class="h4 mb-1"><%= "All contacts" %></h1>
    <p class="text-muted mb-0"><%= "Your relationships from every group, sorted alphabetically by last name." %></p>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Back to dashboard", root_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card mb-4 shadow-sm index-panel index-panel--directory">
  <div class="card-body">
    <%= form_with url: directory_path(format: :turbo_stream), method: :get, data: { turbo_stream: true }, class: "row gy-3 gx-2 align-items-end" do |form| %>
      <div class="col-12 col-md-8 col-lg-9">
        <%= form.label :query, "Search contacts", class: "form-label text-uppercase small text-muted fw-semibold mb-1" %>
        <%= form.search_field :query, value: @query, class: "form-control", placeholder: "Search by name or email" %>
      </div>
      <div class="col-12 col-md-4 col-lg-3 d-flex gap-2 justify-content-md-end">
        <%= form.submit "Search", class: "btn btn-primary flex-grow-1" %>
        <% if @query.present? %>
          <%= link_to "Reset", directory_path(format: :turbo_stream), class: "btn btn-outline-secondary", data: { turbo_stream: true } %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%= turbo_frame_tag "directory_list" do %>
  <%= render partial: "people", locals: { people: @people, user_groups: @user_groups, query: @query } %>
<% end %>
