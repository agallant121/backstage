<%= form_with model: @post, local: true, html: { class: "card shadow-sm" } do |f| %>
  <div class="card-body d-flex flex-column gap-3">
    <% if @post.errors.any? %>
      <div class="alert alert-danger mb-0">
        <h2 class="h6 mb-2"><%= "#{pluralize(@post.errors.count, "error")} prevented this post from saving:" %></h2>
        <ul class="mb-0 ps-3">
          <% @post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-floating">
      <%= f.text_area :body, rows: 5, class: "form-control", placeholder: "What's going on?", style: "height: 150px" %>
      <%= f.label :body, "What's going on?" %>
      <div class="form-text"><%= "Share a quick update to one group or everyone." %></div>
    </div>

    <div>
      <label class="form-label"><%= "Send to group" %></label>
      <%= f.collection_select :group_id,
                              current_user.groups,
                              :id,
                              :name,
                              { include_blank: "All Groups", selected: @group&.id },
                              { class: "form-select" } %>
      <div class="form-text"><%= "Choose one group or leave blank to send to every group." %></div>
    </div>

    <div>
      <label class="form-label"><%= "Attach images" %></label>
      <%= f.file_field :images, multiple: true, class: "form-control" %>
      <div class="form-text"><%= "Images will resize to fit on mobile." %></div>
    </div>
  </div>
  <div class="card-footer bg-white d-flex justify-content-between">
    <%= link_to "Cancel", root_path, class: "btn btn-outline-secondary" %>
    <%= f.submit "Post", class: "btn btn-primary" %>
  </div>
<% end %>
