<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2 page-intro page-intro--posts">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Updates" %></p>
    <h1 class="h4 mb-0"><%= "All posts from your groups" %></h1>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "New Post", new_post_path, class: "btn btn-primary" %>
  </div>
</div>

<%= turbo_frame_tag "posts_list" do %>
  <%= render "posts_index_list", posts: @posts, view_mode: @view_mode %>
<% end %>
