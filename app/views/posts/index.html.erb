<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Updates" %></p>
    <h1 class="h4 mb-0"><%= "All posts from your groups" %></h1>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <%= link_to "New Post", new_post_path, class: "btn btn-primary" %>
  </div>
</div>

<%= turbo_frame_tag "posts_list" do %>
  <div class="d-flex justify-content-end mb-3">
    <% toggle_path = @view_mode == :full ? posts_path : posts_path(view: "full") %>
    <%= link_to(@view_mode == :full ? "Show summaries" : "Show full posts", toggle_path, class: "btn btn-outline-secondary btn-sm") %>
  </div>

  <% if @posts.any? %>
    <div class="d-flex flex-column gap-3">
      <% @posts.each do |post| %>
        <div class="card shadow-sm post-card">
          <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
              <div>
                <p class="post-meta small mb-1"><%= "Posted by " + (post.user&.email || "Unknown author") %></p>
                <p class="post-meta small mb-0"><%= "Posted " + time_ago_in_words(post.created_at) + " ago" %></p>
              </div>
              <div class="d-flex align-items-start gap-3 flex-wrap">
                <% if post.groups.any? %>
                  <div class="d-flex flex-wrap gap-2">
                    <% post.groups.order(:name).each do |group| %>
                      <span class="badge text-bg-light border"> <%= group.name %> </span>
                    <% end %>
                  </div>
                <% end %>
                <div class="d-flex align-items-center gap-3 small text-body">
                  <%= link_to post_path(post), data: { turbo: false }, class: "text-decoration-none d-inline-flex align-items-center gap-1 fw-semibold" do %>
                    <span class="text-primary" aria-hidden="true">↗</span> <span class="text-body-emphasis"><%= "Open" %></span>
                  <% end %>
                  <%= link_to edit_post_path(post), data: { turbo: false }, class: "text-decoration-none d-inline-flex align-items-center gap-1" do %>
                    <span class="text-secondary" aria-hidden="true">✏️</span> <span class="text-body-emphasis"><%= "Edit" %></span>
                  <% end %>
                  <%= link_to post_path(post), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "text-decoration-none d-inline-flex align-items-center gap-1 text-danger" do %>
                    <span aria-hidden="true">🗑️</span> <span class="text-body-emphasis"><%= "Delete" %></span>
                  <% end %>
                </div>
              </div>
            </div>

            <div class="fs-6">
              <% if @view_mode == :full %>
                <%= simple_format(post.body) %>
              <% else %>
                <% truncated_summary = post.body.to_s.length > 160 %>
                <%= simple_format(truncate(post.body, length: 160)) %>

                <% if truncated_summary || post.images.attached? %>
                  <div class="d-flex flex-wrap align-items-center gap-2 small mt-3">
                    <% if truncated_summary %>
                        <span class="badge rounded-pill text-bg-light border border-primary text-primary-emphasis d-inline-flex align-items-center gap-1 px-3 py-2">
                          <span aria-hidden="true">📖</span>
                          <span class="fw-semibold"><%= "More to read" %></span>
                        </span>
                      <% end %>
                      <% if post.images.attached? %>
                        <span class="badge rounded-pill text-bg-light border border-success text-success-emphasis d-inline-flex align-items-center gap-1 px-3 py-2">
                          <span aria-hidden="true">📷</span>
                          <span class="fw-semibold"><%= "Includes photos" %></span>
                        </span>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
            </div>

            <% if @view_mode == :full && post.images.attached? %>
              <% single_image = post.images.one? %>
              <hr class="muted-divider">
              <div class="d-flex flex-column gap-2">
                <p class="fw-semibold mb-1"><%= "Images" %></p>
                <div class="post-attachment-grid <%= "post-attachment-grid-single" if single_image %>">
                  <% post.images.each do |image| %>
                    <div class="post-attachment <%= "post-attachment-single" if single_image %>">
                      <%= image_tag(image, class: "img-fluid w-100 h-auto", loading: "lazy", decoding: "async") %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-light border"><%= "No posts yet. Share something to kick things off!" %></div>
  <% end %>
<% end %>
