<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <p class="text-uppercase text-muted small mb-1"><%= "Post" %></p>
    <h1 class="h4 mb-0"><%= "Shared update" %></h1>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to "Back", posts_path, class: "btn btn-outline-secondary" %>
    <%= link_to "Edit", edit_post_path(@post), class: "btn btn-outline-primary" %>
  </div>
</div>

<div class="card shadow-sm mb-3 post-card">
  <div class="card-body d-flex flex-column gap-3">
    <div>
      <p class="text-muted small mb-1"><%= "Posted " + @post.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
      <div class="fs-5">
        <%= simple_format(@post.body) %>
      </div>
    </div>

    <% groups = @post.groups.order(:name) %>
    <% if groups.any? %>
      <div class="d-flex flex-wrap gap-2">
        <span class="fw-semibold"><%= "Sent to:" %></span>
        <% groups.each do |group| %>
          <span class="badge text-bg-light border"><%= group.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<% if @post.images.attached? %>
  <div class="card shadow-sm post-card">
    <div class="card-body d-flex flex-column gap-2">
      <h2 class="h5 mb-1"><%= "Images" %></h2>
      <div class="post-attachment-grid">
        <% @post.images.each do |image| %>
          <div class="post-attachment">
            <%= image_tag(image, class: "img-fluid w-100 h-auto", loading: "lazy", decoding: "async") %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
