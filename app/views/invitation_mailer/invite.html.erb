<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 18px;">
  <tr>
    <td style="padding: 6px 12px; background-color: rgba(127, 209, 200, 0.18); border: 1px solid rgba(127, 209, 200, 0.4); border-radius: 999px; font-size: 12px; font-weight: 700; color: #3c8d85; text-transform: uppercase; letter-spacing: 0.08em;">
      <%= "Invitation" %>
    </td>
  </tr>
</table>
<h1 style="margin: 0 0 12px; font-size: 26px; font-weight: 750; color: #1d2329;"><%= "You're invited to join" %> <span style="color: #3c8d85;"><%= @group.name %></span></h1>
<p style="margin: 0 0 16px; font-size: 15px; line-height: 1.7; color: #2d3035;">
  <strong><%= @inviter.display_name %></strong> <%= "invited you to join the" %> <strong><%= @group.name %></strong> <%= "group on Backstage." %>
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin: 0 0 24px; border-radius: 14px; background-color: #f6fbfa; border: 1px solid rgba(127, 209, 200, 0.35);">
  <tr>
    <td style="padding: 16px 18px; font-size: 14px; line-height: 1.6; color: #2d3035;">
      <%= "Accept the invitation to see the latest updates and connect with the group. We will set up your profile and bring you right to the group space." %>
    </td>
  </tr>
</table>
<p style="margin: 0 0 16px; font-size: 13px; color: #71757c;"><%= "This invite link expires on #{I18n.l(@expires_at.to_date, format: :long)}." %></p>
<table role="presentation" cellpadding="0" cellspacing="0" style="margin: 0 0 24px;">
  <tr>
    <td style="background-color: #7FD1C8; border-radius: 12px; box-shadow: 0 10px 18px rgba(127, 209, 200, 0.35);">
      <a href="<%= @accept_url %>" style="display: inline-block; padding: 12px 24px; font-size: 15px; font-weight: 700; color: #ffffff; text-decoration: none;"><%= "Accept invitation" %></a>
    </td>
  </tr>
</table>
<p style="margin: 0 0 8px; font-size: 13px; color: #71757c;"><%= "If the button does not work, copy and paste this link into your browser:" %></p>
<p style="margin: 0; font-size: 13px; color: #3c8d85; word-break: break-all;">
  <a href="<%= @accept_url %>" style="color: #3c8d85; text-decoration: none;"><%= @accept_url %></a>
</p>
